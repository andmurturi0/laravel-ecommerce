APP_NAME="Projektii SaaS"
APP_ENV=production
APP_KEY=base64:$(php artisan key:generate --show)
APP_DEBUG=false
APP_URL=https://projektii.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# MySQL Configuration (Production)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=projektii_db
DB_USERNAME=admin
DB_PASSWORD=your_secure_password

# Redis Configuration (Performance Boost)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

SESSION_DRIVER=redis
SESSION_LIFETIME=43200
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true

CACHE_STORE=redis
CACHE_PREFIX=projektii_

QUEUE_CONNECTION=redis

# Filesystem
FILESYSTEM_DISK=public

# Email via Resend.com
MAIL_MAILER=resend
RESEND_API_KEY=re_123456789
MAIL_FROM_ADDRESS="no-reply@projektii.com"
MAIL_FROM_NAME="${APP_NAME}"

# Stripe (Future expansion)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Socialite
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# Optimization
VITE_APP_NAME="${APP_NAME}"
